{
  "name": "discord-clone",
  "version": "0.4.1",
  "private": true,
  "license": "Unlicense",
  "description": "Self-hosted, no-fluff Discord-server clone. See SPEC.md.",
  "scripts": {
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run tauri dev",
    "build:server": "npm --prefix server run build",
    "build:client": "npm --prefix client run build",
    "cli:server": "npm --prefix server run cli --",
    "typecheck": "npm --prefix server run typecheck && npm --prefix client run check",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  }
}
