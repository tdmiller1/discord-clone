# Root .env for docker-compose. Copy to .env and fill in. (.env is gitignored.)
# These drive the Compose stack (server + web + cloudflared). Per-server runtime
# settings live in server/.env.example; the canonical list is SPEC.md §12.

# Released server image to pull from GHCR (ghcr.io/tdmiller1/discord-clone-server).
# Defaults to `latest`; pin a released version (e.g. 0.3.1) for stability. Update
# with `docker compose pull && docker compose up -d`.
SERVER_IMAGE_TAG=

# Released web-client image to pull from GHCR (ghcr.io/tdmiller1/discord-clone-web).
# Defaults to `latest`; pin a released version (e.g. 0.4.0) for stability. Same
# update path: `docker compose pull web && docker compose up -d web`.
WEB_IMAGE_TAG=

# Cloudflare Tunnel connector token (remotely-managed tunnel). The public
# hostname -> service mapping lives in the Cloudflare dashboard. cloudflared runs
# on host networking, so dashboard origins use http://localhost:<port>:
#   - API/gateway -> http://localhost:8080
#   - web client  -> http://localhost:8083
CLOUDFLARE_TUNNEL_TOKEN=

# Public IPv4 the SFU advertises to clients for WebRTC media (mediasoup
# announcedIp). Must be routable and have UDP RTC_MIN_PORT-RTC_MAX_PORT
# port-forwarded directly on the router (NOT via the tunnel). Defaults to
# localhost for local-only dev.
PUBLIC_HOST=

# NOTE: VITE_SERVER_URL / VITE_APP_URL below are baked into the web bundle at BUILD
# time. The published GHCR web image is built by CI from the repo Actions Variables
# of the same name — so when pulling the image (the default above), set them there,
# not here. These two only take effect for a local `docker build`/dev build.

# Server URL baked into the hosted web client bundle so it targets the public API
# by default (e.g. https://discord.example.com). Leave unset for a local build.
VITE_SERVER_URL=

# Public URL of the hosted web client itself (e.g. https://app.example.com). Baked in
# so the in-app "Invite a friend" button generates shareable links that open this client
# with the invite token prefilled. Falls back to the current page origin when unset.
VITE_APP_URL=
