# PRODUCTION env for deploy/docker-compose.yml. Copy to .env and fill in.
# (deploy/.env is gitignored.) Compose auto-loads .env from this directory.
#
# This drives the prod stack (server pulled from GHCR + Caddy TLS). Per-server
# runtime settings come from the server image's loadConfig(); the canonical var
# list is SPEC.md §12.

# ---- Required (no safe default — `docker compose up` fails fast if unset) ----

# Released image tag to pull (story 002 image contract). Defaults to `latest` if
# left empty, but PIN a specific released <version> in prod, e.g. 0.2.0.
#   <version> == ${GITHUB_REF_NAME#v} == root package.json .version
SERVER_IMAGE_TAG=

# Real routable public IPv4/hostname the SFU announces as the WebRTC ICE address
# (SPEC.md §11). NEVER localhost in prod — remote voice silently fails otherwise.
# The UDP RTC_MIN_PORT-RTC_MAX_PORT range (40000-40010) must be port-forwarded
# directly to this host (NOT via Caddy/tunnel — it is raw DTLS-SRTP, not HTTP).
PUBLIC_HOST=

# Public domain Caddy serves TLS for, e.g. discord.example.com. Its DNS A/AAAA
# record MUST resolve to this host before bring-up, or Let's Encrypt issuance
# (HTTP-01 / TLS-ALPN) fails and Caddy retries.
CADDY_SITE=

# ---- Recommended / optional ----

# ACME account + cert-expiry-notice email. Optional but recommended; Caddy will
# issue certs without an account email if left empty.
CADDY_ACME_EMAIL=

# ---- Optional server tuning (defaults match loadConfig() / SPEC.md §12) ----

# Extra ICE candidate IPs (comma-separated), e.g. the host's LAN IP so on-LAN
# clients reach the SFU directly. Each extra IP consumes one more UDP port per
# transport from the range below.
RTC_EXTRA_ANNOUNCED_IPS=

MAX_UPLOAD_MB=10
SESSION_TTL=604800
AUTH_RATE_MAX=10
AUTH_RATE_WINDOW_MS=60000

# ---- UDP media range (CLAUDE.md hard rule: keep these in sync) ----
#
# The compose pins the SFU media range at 40000-40010 in BOTH the UDP port
# mapping AND the server's RTC_MIN_PORT/RTC_MAX_PORT env. Do not change one
# without the other. This must also reach the container directly: allow it in
# the host firewall and UDP-forward it on the router to PUBLIC_HOST. It does NOT
# go through Caddy.

# ---- GHCR access ----
#
# The published package may be PRIVATE on first publish — anonymous `docker pull`
# fails until it is made public or this host authenticates:
#   echo "<PAT-with-read:packages>" | docker login ghcr.io -u tdmiller1 --password-stdin
# See story 002's image contract for both paths; full runbook in story 005.
