# Copy to .env for local runs. See SPEC.md §12.
NODE_ENV=development
HTTP_PORT=8080
DATA_DIR=./data
PUBLIC_HOST=localhost
RTC_MIN_PORT=40000
RTC_MAX_PORT=40100
MAX_UPLOAD_MB=10
SESSION_TTL=604800
# Rate limit for the register/login endpoints (per IP). Optional; sane defaults below.
AUTH_RATE_MAX=10
AUTH_RATE_WINDOW_MS=60000
