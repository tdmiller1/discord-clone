# Copy to .env for local runs. See SPEC.md §12.
NODE_ENV=development
HTTP_PORT=8080
DATA_DIR=./data
PUBLIC_HOST=localhost
# UDP media range for the SFU. Must match the compose UDP port mapping
# (40000-40010) in docker-compose.yml and deploy/docker-compose.yml.
RTC_MIN_PORT=40000
RTC_MAX_PORT=40010
MAX_UPLOAD_MB=10
SESSION_TTL=604800
# Rate limit for the register/login endpoints (per IP). Optional; sane defaults below.
AUTH_RATE_MAX=10
AUTH_RATE_WINDOW_MS=60000
# Text channels / message history (M2). Optional; defaults below.
MAX_MESSAGE_LENGTH=4000
MSG_HISTORY_DEFAULT_LIMIT=50
MSG_HISTORY_MAX_LIMIT=100
