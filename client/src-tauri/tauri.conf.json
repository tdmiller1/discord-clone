{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "discord-clone",
  "version": "0.4.1",
  "identifier": "com.discordclone.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "discord-clone",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2MDFDNDk4OUI3MzlDNUQKUldSZG5IT2JtTVFCVm5nYTM1UjVUdnZiUVNldDk4dkFaWjA2TGhXVDMwVFRQSC92bE5FS3JqUEoK",
      "endpoints": [
        "https://github.com/tdmiller1/discord-clone/releases/latest/download/latest.json"
      ]
    }
  }
}
